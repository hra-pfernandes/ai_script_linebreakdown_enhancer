      ]
    },
    {
      "insertion_id": 3,
      "phase": "final_join_detail_column",
      "description": "Price_Breakdown_Detail correlated subquery as last column in FINAL_JOIN SELECT",
      "role_table": "#Step7",
      "anchor_preview": "Into #Step7",
      "anchor_line_number": 1942,
      "insertion_ends_at_line": 1959,
      "lines_added": 17,
      "chars_added": 953,
      "new_content_preview": ", [Price_Breakdown_Detail] = (\n\t\tSELECT STRING_AGG(\n\t\t\t'Seq:'  + CAST(lb.[Sequence]           AS VARCHAR(MAX)) +\n\t\t\t' CPT:' + ISNULL(CAST(lb.[ProcedureCode]  AS VARCHAR(MAX)), '') +\n\t\t\t' Rev:' + ISNULL(CAST(lb.[RevenueCode]    AS VARCHAR(MAX)), '') +\n\t\t\t' | Cat:'      + CAST(lb.[ServiceCategory]   AS VARCHAR(MAX)) +\n\t\t\t' | Method:'   + CAST(lb.[PricingMethod]     AS VARCHAR(MAX)) +\n\t\t\t' | Billed:$'  + CAST(CONVERT(DECIMAL(12,2), ISNULL(lb.[BilledAmount], 0))  AS VARCHAR(MAX)) +\n\t\t\t' | Paid:$'    + CAST(CONVERT(DECIMAL(12,2), ISNULL(lb.[LinePayment],   0))  AS VARCHAR(MAX)) +\n\t\t\t' | NCCI:'     "
    },
