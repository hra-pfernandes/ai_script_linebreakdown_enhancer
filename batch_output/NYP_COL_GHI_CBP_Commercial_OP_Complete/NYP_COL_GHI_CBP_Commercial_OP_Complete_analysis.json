    "_classification_notes": {
      "Cardiac_Cath": "agg_date=MAX, agg_enc=SUM \u2192 HYBRID by evidence table rules. However evidence table shows agg_date_raw=MAX and agg_enc_raw=SUM. HYBRID classification applies. NOTE: #Step4 applies encounter-level MAX suppression via IIF chain. The HYBRID classification means one winner per ServiceDate, then summed across dates.",
      "PTCA": "agg_date=MAX, agg_enc=SUM \u2192 HYBRID by evidence table rules.",
      "Lithotripsy": "agg_date=MAX, agg_enc=SUM \u2192 HYBRID by evidence table rules.",
      "Chemotherapy": "agg_date=MAX, agg_enc=SUM \u2192 HYBRID by evidence table rules.",
      "IOP": "agg_date=MAX, agg_enc=SUM \u2192 HYBRID by evidence table rules. Placeholder $0 column but pattern is HYBRID.",
      "Partial_Hospitalization": "agg_date=MAX, agg_enc=SUM \u2192 HYBRID. Placeholder $0.",
      "Observation": "agg_date=MAX, agg_enc=SUM \u2192 HYBRID. Placeholder $0.",
