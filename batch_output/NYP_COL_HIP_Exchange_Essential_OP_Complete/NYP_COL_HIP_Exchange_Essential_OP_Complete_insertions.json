      "lines_added": 530,
      "chars_added": 26414,
      "new_content_preview": "\n--=======================================================================\n-- *** [PRICE BREAKDOWN - INSERTED SECTION] ***\n-- SOURCE  : #Step3 (line-level pricing, post-inline suppression, pre-hierarchy)\n--           joined to #Step4 for encounter-level suppression decisions.\n--           #Step2 joined for Sequence, Amount, BillCharges, Quantity\n--           (not present in #Step3 explicit column list).\n--\n-- CONFIRMED #Step3 COLUMNS:\n--   EncounterID, ServiceDate, RevenueCode, ProcedureCode,\n--   OP_Default, [Other OP], ER, AS, Cardiac_Cath, Vascular_Angioplasty,\n--   PTCA_Cardiac_Cath, PTCA_",
      "confirmed_output_columns": [
        "EncounterID",
        "Sequence",
        "ProcedureCode",
        "RevenueCode",
        "ServiceDate",
        "BilledAmount",
        "Quantity",
        "BillCharges",
        "ServiceCategory",
        "PricingMethod",
        "LinePayment",
        "BundledByNCCI"
      ]
    },
    {
      "insertion_id": 3,
      "phase": "final_join_detail_column",
      "description": "Price_Breakdown_Detail correlated subquery as last column in FINAL_JOIN SELECT before INTO #Step7",
      "role_table": "#Step7",
      "anchor_preview": "Into #Step7",
      "anchor_line_number": 1359,
      "insertion_ends_at_line": 1372,
      "lines_added": 13,
      "chars_added": 624,
      "new_content_preview": ", [Price_Breakdown_Detail] = (\n\t\tSELECT STRING_AGG(\n\t\t\t'Seq:'  + CAST(lb.[Sequence]        AS VARCHAR(MAX)) +\n\t\t\t' CPT:' + ISNULL(CAST(lb.[ProcedureCode] AS VARCHAR(MAX)), '') +\n\t\t\t' Rev:' + ISNULL(CAST(lb.[RevenueCode]   AS VARCHAR(MAX)), '') +\n\t\t\t' | Cat:'     + CAST(lb.[ServiceCategory]  AS VARCHAR(MAX)) +\n\t\t\t' | Billed:$' + CAST(CONVERT(DECIMAL(12,2), ISNULL(lb.[BilledAmount], 0)) AS VARCHAR(MAX)) +\n\t\t\t' | Paid:$'   + CAST(CONVERT(DECIMAL(12,2), ISNULL(lb.[LinePayment],   0)) AS VARCHAR(MAX))\n\t\t, ' || ')\n\t\tWITHIN GROUP (ORDER BY lb.[Sequence])\n\t\tFROM #LineBreakdown lb\n\t\tWHERE lb.[Encounter"
    },
