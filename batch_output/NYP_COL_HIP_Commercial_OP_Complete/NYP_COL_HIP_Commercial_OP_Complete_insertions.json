      "anchor_preview": ", [COVID]\n\nINTO #Step4\nFROM #Step3_2",
      "anchor_line_number": 607,
      "insertion_ends_at_line": 1180,
      "lines_added": 573,
      "chars_added": 28448,
      "new_content_preview": "\n--=======================================================================\n-- *** [PRICE BREAKDOWN - INSERTED SECTION] ***\n-- SOURCE  : #Step3 (line-level, post-inline suppression, pre-aggregation)\n--           joined to #Step4 for encounter-level suppression decisions.\n--           #Step2 joined back on EncounterID+Sequence to recover\n--           Sequence, Quantity, BillCharges (not carried into #Step3).\n--\n-- COLUMN SURVIVAL TRACE:\n--   #Step3 is built with an EXPLICIT column list from #Step2.\n--   Confirmed present in #Step3:\n--     EncounterID, ServiceDate, RevenueCode, ProcedureCode, Mod",
      "confirmed_output_columns": [
        "EncounterID",
        "Sequence",
        "ProcedureCode",
        "RevenueCode",
        "ServiceDate",
        "BilledAmount",
        "Quantity",
        "BillCharges",
        "ServiceCategory",
        "PricingMethod",
        "LinePayment",
        "BundledByNCCI"
      ]
    },
    {
      "insertion_id": 3,
      "phase": "final_join_detail_column",
      "description": "Price_Breakdown_Detail correlated subquery as last column in FINAL_JOIN SELECT before INTO clause",
      "role_table": "#Step7",
      "anchor_preview": "Into #Step7",
      "anchor_line_number": 1424,
      "insertion_ends_at_line": 1437,
      "lines_added": 13,
      "chars_added": 622,
      "new_content_preview": ", [Price_Breakdown_Detail] = (\n\t\tSELECT STRING_AGG(\n\t\t\t'Seq:'  + CAST(lb.[Sequence]      AS VARCHAR(MAX)) +\n\t\t\t' CPT:' + ISNULL(CAST(lb.[ProcedureCode] AS VARCHAR(MAX)), '') +\n\t\t\t' Rev:' + ISNULL(CAST(lb.[RevenueCode]   AS VARCHAR(MAX)), '') +\n\t\t\t' | Cat:'     + CAST(lb.[ServiceCategory]  AS VARCHAR(MAX)) +\n\t\t\t' | Billed:$' + CAST(CONVERT(DECIMAL(12,2), ISNULL(lb.[BilledAmount], 0)) AS VARCHAR(MAX)) +\n\t\t\t' | Paid:$'   + CAST(CONVERT(DECIMAL(12,2), ISNULL(lb.[LinePayment],   0)) AS VARCHAR(MAX))\n\t\t, ' || ')\n\t\tWITHIN GROUP (ORDER BY lb.[Sequence])\n\t\tFROM #LineBreakdown lb\n\t\tWHERE lb.[EncounterID"
    },
    {
      "insertion_id": 4,
